# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Supabase — found in your Supabase project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Strava — Client ID is public (safe to expose), found in Strava developer settings
VITE_STRAVA_CLIENT_ID=227043

# Strava — Client SECRET is server-only. Set this in Vercel project settings,
# NOT as a VITE_ variable. It must NOT be prefixed with VITE_.
STRAVA_CLIENT_ID=227043
STRAVA_CLIENT_SECRET=your-client-secret
